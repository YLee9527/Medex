{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Medex",
  "version": "1.1.0",
  "identifier": "com.medex.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Medex",
        "width": 1440,
        "height": 900,
        "minWidth": 1300,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/ffmpeg"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/YLee9527/Medex/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYyQzMzMDE2MjFBQkI1NDYKUldSR3Rhc2hGakREWXZFb2tXQkNqUTVRaVBML0paOW1CY2pmZTdxSlBDUDN0cEhDbGgrR0dBblQK"
    }
  }
}
