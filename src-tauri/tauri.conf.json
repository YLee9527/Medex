{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Medex",
  "version": "0.1.0",
  "identifier": "com.medex.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Medex",
        "width": 1440,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/ffmpeg"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/your-org/medex/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "YOUR_UPDATER_PUBKEY_HERE"
    }
  }
}
